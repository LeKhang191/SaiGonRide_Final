@{
    ViewData["Title"] = "Home Page - SaigonRide";
}

<div class="container py-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border border-primary">
        <div class="container-fluid py-5 text-center">
            <h1 class="display-5 fw-bold text-primary">🚲 SaigonRide</h1>
            <p class="fs-4">Smart bicycle and electric vehicle rental system in Ho Chi Minh City</p>
            <hr class="my-4">
            <p class="text-muted">SaigonRide system dashboard.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="/Account/Register" class="btn btn-primary btn-lg px-4 gap-3">Get Started</a>
                <a href="/Station" class="btn btn-outline-secondary btn-lg px-4">View Station Map</a>
            </div>
        </div>
    </div>

    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        <!-- Khang-->
        <div class="feature col">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-white bg-primary bg-gradient fs-2 mb-3 rounded-3" style="width: 3rem; height: 3rem;">
                    📍
                </div>
                <h3 class="fs-2 text-body-emphasis">Stations & Users</h3>
                <a href="/Station" class="icon-link text-decoration-none">
                    Manage Stations ->
                </a>
            </div>
        </div>

        <div class="feature col">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-white bg-success bg-gradient fs-2 mb-3 rounded-3" style="width: 3rem; height: 3rem;">
                    🚲
                </div>
                <h3 class="fs-2 text-body-emphasis">Fleet (Inventory)</h3>
                <a href="/Vehicle" class="icon-link text-decoration-none text-success">
                    Manage Vehicles ->
                </a>
            </div>
        </div>

        <div class="feature col">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-white bg-warning bg-gradient fs-2 mb-3 rounded-3" style="width: 3rem; height: 3rem;">
                    💰
                </div>
                <h3 class="fs-2 text-body-emphasis">Rental & Payment</h3>
                <a href="/Rental" class="icon-link text-decoration-none text-warning">
                    Rent a Vehicle ->
                </a>
            </div>
        </div>
    </div>
</div>