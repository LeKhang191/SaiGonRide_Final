@{
    ViewData["Title"] = "Home Page - SaigonRide";
}

<div class="container py-5">
    <div class="mb-5 text-center">
        <h1 class="display-4 fw-bold" style="color: #000;">SAIGON RIDE</h1>
        <p class="lead" style="color: #000;">Minimalist Urban Mobility</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm">
                <div class="text-center mb-3">
                    <i class="bi bi-geo-alt-fill fs-1"></i> <i class="bi bi-person-badge fs-1 ms-2"></i>
                </div>
                <h4 class="fw-bold text-center">STATION & USER</h4>
                <p class="text-center small">Manage the network of base stations and the system's customer list.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="/Station" class="btn btn-primary">Manage Stations</a>
                    <a href="/User" class="btn btn-primary">User Directory</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm">
                <div class="text-center mb-3">
                    <i class="bi bi-bicycle fs-1"></i>
                </div>
                <h4 class="fw-bold text-center">FLEET</h4>
                <p class="text-center small">Control the entire fleet, monitor maintenance status, and categorize bicycles/electric vehicles.</p>
                <div class="d-grid mt-auto">
                    <a href="/Vehicle" class="btn btn-primary">Vehicle Management</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 p-4 shadow-sm">
                <div class="text-center mb-3">
                    <i class="bi bi-credit-card-2-front-fill fs-1"></i>
                </div>
                <h4 class="fw-bold text-center">RENTAL & PAYMENT</h4>
                <p class="text-center small">Operate the rental process, return vehicles, and handle automated billing.</p>
                <div class="d-grid mt-auto">
                    <a href="/Rental" class="btn btn-primary">Rental Operations</a>
                </div>
            </div>
        </div>
    </div>
</div>