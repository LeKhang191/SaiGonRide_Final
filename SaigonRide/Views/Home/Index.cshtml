@{
    ViewData["Title"] = "Home Page - SaigonRide";
}

<div class="container py-5">
    <div class="mb-5 text-center">
        <h1 class="display-4 fw-bold text-dark">SAIGON RIDE</h1>
        <p class="lead text-dark">Minimalist Urban Mobility</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 align-items-stretch">
        
        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px;">
                <div class="text-center mb-3">
                    <i class="bi bi-geo-alt-fill fs-1"></i> <i class="bi bi-people-fill fs-1 ms-2"></i>
                </div>
                <h4 class="fw-bold text-center text-dark">STATION & USER</h4>
                <p class="text-center text-dark small">Manage the network of base stations and the system's customer list.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="/Station" class="btn btn-dark" style="border-radius: 50px;">Manage Stations</a>
                    <a href="/User" class="btn btn-dark" style="border-radius: 50px;">User Directory</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px;">
                <div class="text-center mb-3">
                    <i class="bi bi-bicycle fs-1"></i>
                </div>
                <h4 class="fw-bold text-center text-dark">FLEET</h4>
                <p class="text-center text-dark small">Complete vehicle inspection, maintenance status, and classification of bicycles/E-Scooter.</p>
                <div class="d-grid mt-auto">
                    <a href="/Vehicle" class="btn btn-dark" style="border-radius: 50px;">Vehicle Management</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px;">
                <div class="text-center mb-3">
                    <i class="bi bi-credit-card-2-front-fill fs-1"></i>
                </div>
                <h4 class="fw-bold text-center text-dark">RENTAL & PAYMENT</h4>
                <p class="text-center text-dark small">Operate automated car rental, return, and invoice processing systems.</p>
                <div class="d-grid mt-auto">
                    <a href="/Rental" class="btn btn-dark" style="border-radius: 50px;">Rental Operations</a>
                </div>
            </div>
        </div>

    </div>
</div>