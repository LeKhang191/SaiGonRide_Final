@{
    ViewData["Title"] = "Home Page - SaigonRide";
}

<div class="container py-5">
    <div class="mb-5 text-center">
        <h1 class="display-4 fw-bold text-dark text-uppercase" style="letter-spacing: 2px;">SAIGON RIDE</h1>
        <p class="lead text-dark opacity-75">Minimalist Urban Mobility</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 align-items-stretch">
        
        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/station.png" alt="Station Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">STATION & USER</h4>
                <p class="text-center text-dark small px-2">Manage the network of base stations and the system's customer list.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="/Station" class="btn btn-dark" style="border-radius: 50px;">Manage Stations</a>
                    <a href="/Account" class="btn btn-dark" style="border-radius: 50px;">User Directory</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/escooter.png" alt="Fleet Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">FLEET</h4>
                <p class="text-center text-dark small px-2">Complete vehicle inspection, maintenance status, and classification of bicycles/E-Scooter.</p>
                <div class="d-grid mt-auto">
                    <a href="/Vehicle" class="btn btn-dark" style="border-radius: 50px;">Vehicle Management</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 20px; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/payment.png" alt="Payment Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">RENTAL & PAYMENT</h4>
                <p class="text-center text-dark small px-2">Operate automated car rental, return, and invoice processing systems.</p>
                <div class="d-grid mt-auto">
                    <a href="/Rental" class="btn btn-dark" style="border-radius: 50px;">Rental Operations</a>
                </div>
            </div>
        </div>

    </div>
</div>