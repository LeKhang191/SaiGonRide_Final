@{
    ViewData["Title"] = "Home Page - SaigonRide";
}

<style>
    .card, .btn, .flip-card-front, .flip-card-back {
        border-radius: 5px !important;
    }

    .reveal {
        position: relative;
        transform: translateY(50px);
        opacity: 0;
        transition: 1.2s all ease-out;
    }

        .reveal.active {
            transform: translateY(0);
            opacity: 1;
        }

    .flip-card {
        background-color: transparent;
        width: 100%;
        height: 250px;
        perspective: 1000px;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
        box-shadow: 10px 10px 0px #000;
    }

    .flip-card.flipped .flip-card-inner {
        transform: rotateY(180deg);
    }

    .flip-card-front, .flip-card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border: 1px solid #000;
    }

        .flip-card-front img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .flip-card-back {
        background-color: #E8E4D8;
        color: #000;
        transform: rotateY(180deg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 20px;
        text-align: center;
        position: absolute;
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        border: 1px solid #000;
    }

    .flip-card {
        background-color: transparent;
        width: 100%;
        height: 250px;
        perspective: 1000px;
        transition: transform 0.1s ease-out;
        will-change: transform;
    }

    .flip-card-inner {
        pointer-events: none;
    }
</style>

<div class="container py-5">
    <div class="mb-5 text-center">
        <h1 class="display-4 fw-bold text-dark text-uppercase" style="letter-spacing: 2px;">SAIGON RIDE</h1>
        <p class="lead text-dark opacity-75">Minimalist Urban Mobility</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 align-items-stretch">
        
        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 5px !important; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/station.png" alt="Station Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">STATION & USER</h4>
                <p class="text-center text-dark small px-2">Manage the network of base stations and the system's customer list.</p>
                <div class="d-grid gap-2 mt-auto">
                    <a href="/Station" class="btn btn-dark" style="border-radius: 5px !important;">Manage Stations</a>
                    <a href="/Account" class="btn btn-dark" style="border-radius: 5px !important;">User Directory</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 5px !important; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/escooter.png" alt="Fleet Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">FLEET</h4>
                <p class="text-center text-dark small px-2">Complete vehicle inspection, maintenance status, and classification of bicycles/E-Scooter.</p>
                <div class="d-grid mt-auto">
                    <a href="/Vehicle" class="btn btn-dark" style="border-radius: 5px !important;">Vehicle Management</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 p-4 shadow-sm d-flex flex-column" style="background-color: #E8E4D8; border-radius: 5px !important; border: 1px solid rgba(0,0,0,0.1);">
                <div class="text-center mb-3">
                    <img src="~/images/payment.png" alt="Payment Icon" style="height: 60px; width: auto; filter: brightness(0);" />
                </div>
                <h4 class="fw-bold text-center text-dark text-uppercase">RENTAL & PAYMENT</h4>
                <p class="text-center text-dark small px-2">Operate automated car rental, return, and invoice processing systems.</p>
                <div class="d-grid mt-auto">
                    <a href="/Rental" class="btn btn-dark" style="border-radius: 5px !important;">Rental Operations</a>
                </div>
            </div>
        </div>
    </div>

    <div class="about-section reveal mt-5 py-5">
        <div class="row align-items-center">
            <div class="col-md-7">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="flip-card" id="card1">
                            <div class="flip-card-inner">
                                <div class="flip-card-front">
                                    <img src="~/images/scooterbg.jpg" alt="Fleet">
                                </div>
                                <div class="flip-card-back">
                                    <h6 class="fw-bold">SMART FLEET</h6>
                                    <p class="small">Integrated E-Scooters & Bicycles ecosystem.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="flip-card" id="card2">
                            <div class="flip-card-inner">
                                <div class="flip-card-front">
                                    <img src="~/images/e1.jpg" alt="Station">
                                </div>
                                <div class="flip-card-back">
                                    <h6 class="fw-bold">STATION NETWORK</h6>
                                    <p class="small">Strategically located across HCM City.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="flip-card" id="card3">
                            <div class="flip-card-inner">
                                <div class="flip-card-front">
                                    <img src="~/images/e2.jpg" alt="Payment">
                                </div>
                                <div class="flip-card-back">
                                    <h6 class="fw-bold">GLOBAL PAY</h6>
                                    <p class="small">Supporting PayPal & International Gateways.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="flip-card" id="card4">
                            <div class="flip-card-inner">
                                <div class="flip-card-front">
                                    <img src="~/images/e3.jpg" alt="Eco">
                                </div>
                                <div class="flip-card-back">
                                    <h6 class="fw-bold">ECO IMPACT</h6>
                                    <p class="small">Reducing urban carbon footprint daily.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5 ps-md-5 mt-4 mt-md-0">
                <h6 class="text-uppercase fw-bold text-muted mb-2">Our Mission</h6>
                <h2 class="fw-bold text-dark mb-4">REDEFINING URBAN TRANSIT</h2>
                <p class="text-dark">SaigonRide provides a seamless micro-mobility ecosystem designed for the modern rhythm of Ho Chi Minh City.</p>
                <p class="text-dark">By bridging the gap between local commuters and international travelers, we deliver a unified rental experience with real-time balancing.</p>
                <div class="mt-4">
                    <button class="btn btn-dark px-4 py-2" onclick="flipAllCards()">FLIP</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                if (elementTop < windowHeight - 150) {
                    reveals[i].classList.add("active");
                
                    setTimeout(() => { document.getElementById("card1").classList.add("flipped"); }, 800);
                    setTimeout(() => { document.getElementById("card2").classList.add("flipped"); }, 1000);
                    setTimeout(() => { document.getElementById("card3").classList.add("flipped"); }, 1200);
                    setTimeout(() => { document.getElementById("card4").classList.add("flipped"); }, 1400);
                }
            }
        }

        function flipAllCards() {
            for(let i = 1; i <= 4; i++) {
                document.getElementById("card" + i).classList.toggle("flipped");
            }
        }

        const cards = document.querySelectorAll('.flip-card');

        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const cardRect = card.getBoundingClientRect();
                const x = e.clientX - cardRect.left;
                const y = e.clientY - cardRect.top;
            
                const middleX = cardRect.width / 2;
                const middleY = cardRect.height / 2;

                const rotateX = ((y - middleY) / middleY) * -15;
                const rotateY = ((x - middleX) / middleX) * 15;

                const isFlipped = card.classList.contains('flipped');
                const finalRotateY = isFlipped ? (rotateY + 180) : rotateY;

                const inner = card.querySelector('.flip-card-inner');
                inner.style.transform = `rotateX(${rotateX}deg) rotateY(${finalRotateY}deg) scale(1.05)`;
            });

            card.addEventListener('mouseleave', () => {
                const inner = card.querySelector('.flip-card-inner');
                const isFlipped = card.classList.contains('flipped');
            
                inner.style.transition = "transform 0.5s ease";
                inner.style.transform = isFlipped ? "rotateY(180deg)" : "rotateX(0deg) rotateY(0deg)";
            });

            card.addEventListener('mouseenter', () => {
                const inner = card.querySelector('.flip-card-inner');
                inner.style.transition = "none";
            });
        });

        window.addEventListener("scroll", reveal);
        reveal();
    </script>
}
</div>