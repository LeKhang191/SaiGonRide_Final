@model SaigonRide.Models.Entities.Transaction

<div class="container mt-5 text-center">
    <div class="card shadow-lg p-5 mx-auto" style="max-width: 600px; border-top: 5px solid #28a745;">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h2 class="text-success fw-bold">Payment Successful!</h2>
        <p class="text-muted">Thank you for using SaigonRide.</p>
        
        <hr />
        
        <div class="text-start px-4">
            <p><strong>Transaction ID:</strong> #@Model.TransactionId</p>
            <p><strong>Vehicle:</strong> @Model.VehicleNumber</p>
            <p><strong>Amount Paid:</strong> @Model.TotalFare.ToString("N0") VND</p>
            <p><strong>Date:</strong> @Model.PaymentDate.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Method:</strong> @Model.PaymentMethod</p>
        </div>

        <div class="mt-4">
            <a href="/" class="btn btn-primary px-5">Back to Home</a>
            <button onclick="window.print()" class="btn btn-outline-secondary px-4 ms-2">
                <i class="bi bi-printer"></i> Print
            </button>
        </div>
    </div>
</div>