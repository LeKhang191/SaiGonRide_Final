@model IEnumerable<SaigonRide.Models.Entities.User>
@{
    ViewData["Title"] = "Eco Leaderboard";
    Layout = "_Layout";
    int rank = 1;
}

<div class="container py-5" style="max-width: 800px; min-height: 100vh;">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-dark text-uppercase"><i class="bi bi-globe-americas text-success"></i> ECO IMPACT</h1>
        <p class="text-muted">Top 10 SaigonRide heroes saving the planet, one ride at a time.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert text-center" style="background-color: #E8E4D8; border: 1px solid #000;">
            <i class="bi bi-wind fs-3 d-block mb-2"></i>
            <strong>No data yet!</strong> Be the first one to start a ride and save CO2.
        </div>
    }
    else
    {
        <div class="card shadow-lg border-dark" style="border-radius: 5px; overflow: hidden;">
            <div class="card-header text-white text-uppercase fw-bold py-3" style="background-color: #198754; border-bottom: 2px solid #000;">
                <div class="row text-center">
                    <div class="col-2">Rank</div>
                    <div class="col-6 text-start">Rider Name</div>
                    <div class="col-4">CO2 Saved (kg)</div>
                </div>
            </div>
            <div class="card-body p-0" style="background-color: #F5F2E8;">
                @foreach (var user in Model)
                {
                    <div class="row align-items-center text-center py-3 border-bottom border-dark @(rank == 1 ? "bg-warning bg-opacity-25" : "")">
                        <div class="col-2 fw-bold fs-5">
                            @if (rank == 1)
                            {
                                <span class="text-warning"><i class="bi bi-trophy-fill"></i> 1</span>
                            }
                            else if (rank == 2)
                            {

                                <span class="text-secondary"><i class="bi bi-award-fill"></i> 2</span>
                            }
                            else if (rank == 3)
                            {

                                <span style="color: #cd7f32;"><i class="bi bi-award-fill"></i> 3</span>
                            }
                            else
                            {

                                <span class="text-muted">@rank</span>
                            }
                        </div>
                        <div class="col-6 text-start fw-bold text-dark text-uppercase">
                            @user.FullName
                        </div>
                        <div class="col-4 fw-bold text-success fs-5">
                            @((user.TotalCo2Saved / 1000).ToString("0.00")) kg
                        </div>
                    </div>
                    rank++;
                }
            </div>
        </div>
    }
</div>