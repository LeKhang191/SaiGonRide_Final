@model IEnumerable<SaigonRide.Models.Entities.Rental>
@{
    ViewData["Title"] = "Rental Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4" style="background-color: #F5F2E8; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark text-uppercase">🚲 RENTAL OPERATIONS</h2>
            <p class="text-dark mb-0">Monitor and process all vehicle transactions</p>
        </div>
        <a asp-action="StartRental" class="btn btn-dark shadow-sm px-4" style="border-radius: 50px;">
            <i class="bi bi-plus-circle me-1"></i> START NEW RENTAL
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert border-dark text-dark alert-dismissible fade show shadow-sm" style="background-color: #E8E4D8;">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-dark shadow-sm h-100" style="background-color: #E8E4D8; border-radius: 15px;">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-dark">@Model.Count()</div>
                    <div class="text-uppercase small fw-bold">Total Rentals</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-dark shadow-sm h-100" style="background-color: #E8E4D8; border-radius: 15px;">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-dark">@Model.Count(r => r.Status == "Active")</div>
                    <div class="text-uppercase small fw-bold">Active Now</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-dark shadow-sm h-100" style="background-color: #E8E4D8; border-radius: 15px;">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-dark">@Model.Count(r => r.Status == "Completed")</div>
                    <div class="text-uppercase small fw-bold">Completed</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-dark shadow-sm h-100" style="background-color: #000; border-radius: 15px;">
                <div class="card-body text-center">
                    <div class="fs-4 fw-bold text-white">
                        @String.Format("{0:N0}", Model.Where(r => r.FinalFare.HasValue).Sum(r => r.FinalFare))
                    </div>
                    <div class="text-uppercase small fw-bold text-white">Total Revenue (VND)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row text-center mb-5 g-3">
        <div class="col-md-6">
            <div class="card p-3 border-dark shadow-sm" style="background-color: #E8E4D8; border-radius: 20px;">
                <span style="font-size: 2.5rem; filter: grayscale(100%);">🚲</span>
                <h6 class="fw-bold text-dark mt-2">STANDARD BICYCLE</h6>
                <p class="text-dark fw-bold mb-0">500 VND / MIN</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3 border-dark shadow-sm" style="background-color: #E8E4D8; border-radius: 20px;">
                <span style="font-size: 2.5rem; filter: grayscale(100%);">🛴</span>
                <h6 class="fw-bold text-dark mt-2">E-SCOOTER</h6>
                <p class="text-dark fw-bold mb-0">1,500 VND / MIN</p>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden" style="border-radius: 20px;">
        <div class="card-header border-bottom py-3" style="background-color: #E8E4D8;">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-ul me-2"></i>RECENT TRANSACTIONS</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="background-color: #E8E4D8;">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4">#ID</th>
                            <th>USER</th>
                            <th>VEHICLE</th>
                            <th>ROUTE (FROM → TO)</th>
                            <th>START</th>
                            <th>DUR.</th>
                            <th>FARE (VND)</th>
                            <th>STATUS</th>
                            <th class="text-center">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @foreach (var rental in Model)
                        {
                            <tr>
                                <td class="px-4"><span class="fw-bold">#@rental.RentalId</span></td>
                                <td class="fw-bold text-uppercase">@rental.User?.FullName</td>
                                <td>@rental.Vehicle?.VehicleNumber</td>
                                <td>
                                    <span class="badge border border-dark text-dark">@rental.StartStation?.Name</span>
                                    @if (rental.EndStation != null)
                                    {
                                        <span class="mx-1">→</span>
                                        <span class="badge border border-dark text-dark">@rental.EndStation.Name</span>
                                    }
                                </td>
                                <td>@rental.StartTime.ToString("dd/MM HH:mm")</td>
                                <td>
                                    @if (rental.EndTime.HasValue)
                                    {
                                        var dur = (int)(rental.EndTime.Value - rental.StartTime).TotalMinutes;
                                        <span>@dur min</span>
                                    }
                                    else
                                    {
                                        var dur = (int)(DateTime.Now - rental.StartTime).TotalMinutes;
                                        <span class="fw-bold">@dur min (LIVE)</span>
                                    }
                                </td>
                                <td class="fw-bold">
                                    @(rental.FinalFare.HasValue ? String.Format("{0:N0}", rental.FinalFare) : "-")
                                </td>
                                <td>
                                    <span class="badge border border-dark text-dark text-uppercase" style="font-size: 0.7rem;">
                                        @rental.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        @if (rental.Status == "Active")
                                        {
                                            <a asp-action="EndRental" asp-route-id="@rental.RentalId"
                                                   class="btn btn-dark me-1" style="border-radius: 10px;">
                                                <i class="bi bi-flag-fill"></i> END
                                            </a>
                                        }
                                        <a asp-action="Delete" asp-route-id="@rental.RentalId" class="btn btn-outline-dark" ...>

                                            <form asp-controller="Account" asp-action="Delete" asp-route-id="@rental.UserId" method="post"
                                                  onsubmit="return confirm('Delete user @rental.User?.FullName?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-dark" style="border-radius: 10px;">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>