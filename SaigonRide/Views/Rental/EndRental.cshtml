@model SaigonRide.Models.Entities.Rental
@{
    ViewData["Title"] = "Return Vehicle";
    Layout = "_AdminLayout";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-arrow-left"></i> Back to Rentals</a>
        <h2 class="fw-bold mt-2"><i class="bi bi-flag-fill"></i> Return Vehicle</h2>
        <p class="text-muted">Complete the rental and calculate fare</p>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-warning text-dark fw-bold">
            <i class="bi bi-info-circle"></i> Active Rental #@Model.RentalId
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-6">
                    <div class="text-muted small">User</div>
                    <div class="fw-semibold">@Model.User?.FullName</div>
                </div>
                <div class="col-6">
                    <div class="text-muted small">Vehicle</div>
                    <div class="fw-semibold">@Model.Vehicle?.VehicleNumber (@Model.Vehicle?.Type)</div>
                </div>
                <div class="col-6">
                    <div class="text-muted small">Picked up from</div>
                    <div class="fw-semibold">@Model.StartStation?.Name</div>
                </div>
                <div class="col-6">
                    <div class="text-muted small">Start Time</div>
                    <div class="fw-semibold">@Model.StartTime.ToString("HH:mm - dd/MM/yyyy")</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small">Duration so far</div>
                    <div class="fw-semibold text-warning" id="duration-display">Calculating...</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="EndRental" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="rentalId" value="@Model.RentalId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="bi bi-geo-alt"></i> Return Station</label>
                    <select name="endStationId" class="form-select" required asp-items="ViewBag.Stations">
                        <option value="">-- Select Return Station --</option>
                    </select>
                    <div class="form-text text-success">
                        <i class="bi bi-stars"></i> Returning to low-inventory stations earns 15% discount!
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold"><i class="bi bi-credit-card"></i> Payment Method</label>
                    @{
                        bool isTourist = Model.User?.UserType == "Tourist";
                    }
                    <div class="row g-2">
                        @if (!isTourist)
                        {
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="paymentMethod" id="momo" value="MoMo" required>
                                <label class="btn btn-outline-danger w-100" for="momo">MoMo</label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="paymentMethod" id="vnpay" value="VNPay">
                                <label class="btn btn-outline-primary w-100" for="vnpay">VNPay</label>
                            </div>
                        }
                        else
                        {
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="paymentMethod" id="applepay" value="Apple Pay" required>
                                <label class="btn btn-outline-dark w-100" for="applepay">Apple Pay</label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="paymentMethod" id="paypal" value="PayPal">
                                <label class="btn btn-outline-primary w-100" for="paypal">PayPal</label>
                            </div>
                        }
                        <div class="col-4">
                            <input type="radio" class="btn-check" name="paymentMethod" id="cash" value="Cash">
                            <label class="btn btn-outline-success w-100" for="cash">Cash</label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                    Complete & Pay
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const startTime = new Date('@Model.StartTime.ToString("yyyy-MM-ddTHH:mm:ss")');
        function updateDuration() {
            const now = new Date();
            const diffMs = now - startTime;
            const diffMins = Math.floor(diffMs / 60000);
            const diffSecs = Math.floor((diffMs % 60000) / 1000);
            document.getElementById('duration-display').textContent = diffMins + ' min ' + diffSecs + ' sec';
        }
        updateDuration();
        setInterval(updateDuration, 1000);
    </script>
}