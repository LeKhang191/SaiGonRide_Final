<div class="container mt-4">
    <h4>Choose a Station nearby</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card border-primary">
                <div class="card-body">
                    <h5 class="card-title">Ben Thanh Station</h5>
                    <p class="card-text text-muted">District 1, TP.HCM</p>
                    <div class="progress mb-2" style="height: 10px;">
                        <div class="progress-bar bg-success" style="width: 80%"></div>
                    </div>
                    <small>Remain: 40/50 Vehicle (80% utilized)</small>
                    <button class="btn btn-sm btn-primary float-end">Choose Station</button>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card border-danger bg-light">
                <div class="card-body">
                    <h5 class="card-title text-danger">Thao Dien Station</h5>
                    <p class="card-text text-muted">District 2, TP.HCM</p>
                    <div class="progress mb-2" style="height: 10px;">
                        <div class="progress-bar bg-danger" style="width: 10%"></div>
                    </div>
                    <small class="text-danger">Warning: There is only 2 vehicle left (15% Discount)</small>
                </div>
            </div>
        </div>
    </div>
</div>