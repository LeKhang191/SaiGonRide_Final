@model SaigonRide.Models.Entities.Station

<div class="container mt-4">
    <h4>Add New Station</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Station Name</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <input asp-for="Location" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Max Capacity</label>
                    <input asp-for="MaxCapacity" type="number" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary">Save Station</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>