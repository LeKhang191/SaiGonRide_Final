@model SaigonRide.Models.Entities.Vehicle
@{
    ViewData["Title"] = "Create Vehicle";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="background-color: #E8E4D8; border-radius: 25px; border: 1px solid #000;">
                <div class="card-body p-5">
                    <h2 class="fw-bold text-dark mb-4 text-center">ADD NEW VEHICLE</h2>
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label class="form-label">Vehicle Number</label>
                            <input asp-for="VehicleNumber" class="form-control" placeholder="e.g. SR-001" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Available">Available</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-dark">CONFIRM & SAVE</button>
                            <a asp-action="Index" class="btn btn-outline-dark" style="border-radius: 50px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div></div>