@model SaigonRide.Models.Entities.Vehicle
@{
    ViewData["Title"] = "Create Vehicle";
    Layout = "_AdminLayout";
}

<div class="container py-4" style="max-width: 600px;">
    <h2 class="fw-bold mb-4">🚀 Add New Vehicle</h2>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Vehicle Number</label>
                    <input asp-for="VehicleNumber" class="form-control" placeholder="Ex: 72-V1 12345" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Vehicle Type</label>
                    <select asp-for="Type" class="form-select" required>
                        <option value="Standard Bike">Standard Bike</option>
                        <option value="Electric Bike">E-Scooter</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Station</label>
                    <select asp-for="StationId" class="form-select" asp-items="ViewBag.Stations" required>
                        <option value="">-- Select Station --</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Available">Available</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Save Vehicle</button>
            </form>
        </div>
    </div>
</div>