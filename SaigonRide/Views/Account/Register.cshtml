@model SaigonRide.Models.Entities.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - SaigonRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body, html { 
            height: 100%; 
            margin: 0; 
            font-family: 'Segoe UI', sans-serif; 
        }

        .bg-image {
            background-image: url('/images/scooter.jpg');
            background-size: cover; 
            background-position: center;
            height: 100%; display: flex; 
            align-items: center; 
            justify-content: center;
        }

        .register-card {
            background: white; 
            padding: 40px; 
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); 
            width: 100%; max-width: 500px;
        }

        .btn-next {
            background-color: #2D2D2D; 
            color: white; 
            border-radius: 25px;
            padding: 12px; 
            font-weight: bold; 
            border: none; 
            width: 100%; 
            margin-top: 1rem;
        }

        .btn-next:hover { 
            background-color: #000;
        }

        .form-label { 
            font-size: 0.75rem; 
            font-weight: bold; 
            color: #666; 
            text-transform: uppercase;
        }

        .user-type-toggle {
            display: flex; 
            gap: 10px; 
            margin-bottom: 20px;
        }

        .user-type-btn {
            flex: 1; 
            padding: 10px; 
            border: 1px solid #ddd; 
            border-radius: 10px;
            background: white; 
            cursor: pointer; 
            text-align: center; 
            transition: 0.3s;
        }

        .user-type-btn.active {
            background: #007bff; 
            color: white; 
            border-color: #007bff;
        }

        register-card, .login-card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 500px;
            position: relative;
            z-index: 10;
        }
    </style>
</head>
<body>

<div class="bg-image">
    <div class="register-card">
        <div class="mb-3">
            <h4 class="fw-bold">Saigon<span class="text-primary">Ride</span></h4>
        </div>
        <h2 class="fw-bold mb-2">Create an account</h2>
        <p class="text-muted mb-4 small">Join us to start your journey around the city.</p>

            <form asp-controller="Account" asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control form-control-lg" placeholder="Name" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="name@example.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••••" required />
            </div>

            <label class="form-label">Are you a Local or Tourist?</label>
            <div class="user-type-toggle">
                <div class="user-type-btn active" onclick="toggleUserType('Local')">Local</div>
                <div class="user-type-btn" onclick="toggleUserType('Tourist')">Foreign Tourist</div>
            </div>
            <input type="hidden" asp-for="UserType" id="UserType" value="Local Tourist" />

            <div class="mb-4">
                <label id="idLabel" class="form-label">National ID (CCCD)</label>
                <input asp-for="IdNumber" id="IdInput" class="form-control form-control-lg" placeholder="Enter your ID number" required />
            </div>

            <button type="submit" class="btn btn-next">Create Account</button>
        </form>

        <div class="text-center mt-3 small">
            Already have an account?
            <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold">Login</a>
        </div>
    </div>
</div>

<script>
    function toggleUserType(type) {
        document.getElementById('UserType').value = type;
        
        const btns = document.querySelectorAll('.user-type-btn');
        btns.forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');

        const label = document.getElementById('idLabel');
        const input = document.getElementById('IdInput');
        
        if (type === 'Local') {
            label.innerText = 'National ID (CCCD)';
            input.placeholder = 'Enter 12-digit CCCD';
        } else {
            label.innerText = 'Passport Number';
            input.placeholder = 'Enter your Passport number';
        }
    }
</script>

</body>
</html>