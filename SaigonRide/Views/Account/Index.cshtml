@model IEnumerable<SaigonRide.Models.Entities.User>

@{
    ViewData["Title"] = "User Directory";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-person-fill"></i> User Directory</h2>
        <span class="badge bg-info text-dark">Total: @Model.Count()</span>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 5px; overflow: hidden;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0" style="border-collapse: collapse;">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4 py-3">Name</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">User Type</th>
                        <th class="py-3">ID Number</th>
                        <th class="pe-4 text-end py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="align-middle" style="background-color: #E8E4D8;">
                            <td class="ps-4 fw-bold">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.UserType == "Local" ? "bg-success" : "bg-warning text-dark")">
                                    @user.UserType
                                </span>
                            </td>
                            <td>@user.IdNumber</td>
                            <td class="pe-4 text-end">
                                <form asp-controller="Account" asp-action="Delete" asp-route-id="@user.UserId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete the user @user.FullName?');"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 5px;">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>