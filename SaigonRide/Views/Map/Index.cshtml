@model IEnumerable<SaigonRide.Models.Entities.Station>
@{
    ViewData["Title"] = "SaigonRide - Live Map";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container-fluid py-4" style="background-color: #F5F2E8;">
    <h2 class="fw-bold text-dark text-uppercase mb-4"><i class="bi bi-geo-alt-fill"></i> Live Stations Map</h2>
    
    <div id="map" style="height: 600px; border: 2px solid #000; border-radius: 5px;"></div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map = L.map('map').setView([10.762622, 106.660172], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var stations = @Html.Raw(Json.Serialize(Model));

        stations.forEach(function(station) {
            if(station.latitude && station.longitude) {
                L.marker([station.latitude, station.longitude])
                 .addTo(map)
                 .bindPopup(`
                    <b style="font-family: 'Arial';">${station.name}</b><br>
                    Vehicles currently available: ${station.currentInventory}<br>
                    <a href="/Rental/StartRental?stationId=${station.stationId}" class="btn btn-sm btn-dark text-white mt-2" style="font-size:10px;">RENT HERE</a>
                 `);
            }
        });
    </script>
}